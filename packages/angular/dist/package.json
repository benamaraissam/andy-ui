{
  "name": "@andy-ui/angular",
  "version": "0.1.0",
  "description": "Angular bindings for Andy-UI web components (form-control directives + element registration).",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "peerDependencies": {
    "@angular/common": ">=17",
    "@angular/core": ">=17",
    "@angular/forms": ">=17"
  },
  "dependencies": {
    "@andy-ui/core": "workspace:^",
    "tslib": "^2.8.1"
  },
  "module": "fesm2022/andy-ui-angular.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/andy-ui-angular.mjs"
    }
  },
  "sideEffects": false
}